* text=auto

.htaccess text eol=lf
*.php text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.txt text eol=lf

# Binary assets — never normalize EOL/charset (protects dompdf fonts & images).
*.ttf binary
*.ttc binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.ufm binary
