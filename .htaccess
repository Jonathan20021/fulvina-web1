DirectoryIndex index.php
ErrorDocument 404 /fulvina-web/404.php

<IfModule mod_rewrite.c>
  RewriteEngine On

  # canonical host: send the staging subdomain straight to the public domain
  RewriteCond %{HTTP_HOST} ^(www\.)?schmedicos\.kyrosrd\.com$ [NC]
  RewriteRule ^ https://schmedicos.com%{REQUEST_URI} [R=301,L]

  # force HTTPS (skip when behind a proxy that already terminated TLS)
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # index.php (any level) -> clean directory root
  RewriteCond %{THE_REQUEST} \s/+(.*?)index\.php[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L,NE]

  # any other "*.php" -> extensionless clean URL
  RewriteCond %{THE_REQUEST} \s/+([^.\s?]+)\.php[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L,NE]

  # serve "/route" from "/route.php" when the file exists
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.php -f
  RewriteRule ^(.+?)/?$ $1.php [L]
</IfModule>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<FilesMatch "^(PRODUCT|DESIGN)\.md$">
  Require all denied
</FilesMatch>

<Files "schema.sql">
  Require all denied
</Files>
